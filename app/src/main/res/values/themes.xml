<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cory_accent</item>
        <item name="colorPrimaryVariant">@color/cory_accent</item>
        <item name="colorOnPrimary">@color/cory_white</item>
        <item name="colorSecondary">@color/cory_surface_alt</item>
        <item name="colorSecondaryVariant">@color/cory_surface_alt</item>
        <item name="colorOnSecondary">@color/cory_text</item>
        <!--
          Status bar is dark navy (matches windowBackground), with
          LIGHT icons (windowLightStatusBar=false) so they're visible
          over the dark bg. Was: transparent + light status bar
          (=dark icons) which made the system bar essentially
          invisible on the dark Compose Surface.
        -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/cory_canvas</item>
        <item name="android:navigationBarColor">@color/cory_canvas</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowBackground">@color/cory_canvas</item>
    </style>
</resources>
