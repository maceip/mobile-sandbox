<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/cory_backdrop"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/hero_eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:text="@string/hero_eyebrow"
                android:textAllCaps="true"
                android:textColor="@color/cory_accent"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/hero_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/hero_title"
                android:textColor="@color/cory_text"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/hero_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/hero_subtitle"
                android:textColor="@color/cory_muted"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/status_line"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/cory_status_block"
            android:fontFamily="monospace"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="@string/status_ready"
            android:textColor="@color/cory_text"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="240dp"
            android:layout_height="match_parent"
            android:background="@drawable/cory_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/workspace_label"
                android:textAllCaps="true"
                android:textColor="@color/cory_accent"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/new_file_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/new_file_button" />

                <Button
                    android:id="@+id/new_dir_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/new_dir_button" />
            </LinearLayout>

            <ListView
                android:id="@+id/workspace_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:background="@drawable/cory_status_block"
                android:choiceMode="singleChoice"
                android:divider="@color/cory_stroke"
                android:dividerHeight="1dp"
                android:padding="6dp" />

            <TextView
                android:id="@+id/storage_summary"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/cory_status_block"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:maxLines="4"
                android:padding="12dp"
                android:textColor="@color/cory_muted"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:background="@drawable/cory_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/editor_label"
                        android:textAllCaps="true"
                        android:textColor="@color/cory_accent"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/current_file_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace"
                        android:text="@string/current_file_empty"
                        android:textColor="@color/cory_text"
                        android:textSize="13sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/save_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/save_button" />

                <Button
                    android:id="@+id/run_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/run_button" />
            </LinearLayout>

            <EditText
                android:id="@+id/script_editor"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:background="@drawable/cory_status_block"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:inputType="textMultiLine|textNoSuggestions"
                android:padding="16dp"
                android:scrollbars="vertical"
                android:textColor="@color/cory_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/native_summary"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/cory_status_block"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:maxLines="4"
                android:padding="12dp"
                android:textColor="@color/cory_muted"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/cory_panel"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/console_label"
            android:textAllCaps="true"
            android:textColor="@color/cory_accent"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/console_output"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/cory_status_block"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:padding="12dp"
            android:text="@string/terminal_empty"
            android:textColor="@color/cory_text"
            android:textIsSelectable="true"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/command_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/cory_status_block"
                android:fontFamily="monospace"
                android:hint="@string/command_hint"
                android:imeOptions="actionDone"
                android:inputType="textNoSuggestions"
                android:padding="12dp"
                android:textColor="@color/cory_text"
                android:textSize="13sp" />

            <Button
                android:id="@+id/command_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/command_button" />

            <Button
                android:id="@+id/clear_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/clear_button" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
